# --- Configuracion Redis / Cache ---
# Tamano maximo de la cache en Redis (probar 50mb, 200mb, 500mb)
REDIS_MAXMEMORY=200mb
# Politica NATIVA de Redis:
# - allkeys-lru  -> para CACHE_POLICY=LRU
# - allkeys-lfu  -> para CACHE_POLICY=LFU
# - noeviction   -> para CACHE_POLICY=FIFO (manejado por cliente)
REDIS_POLICY_NATIVE=allkeys-lru
REDIS_PORT_HOST=6380

# Politica a nivel del cache_api. Valores validos: LRU, LFU, FIFO.
CACHE_POLICY=LRU

# TTL global default (segundos). 0 = sin expiracion.
CACHE_TTL_SEC=300

# TTL especificos por tipo de consulta
TTL_Q1=300
TTL_Q2=300
TTL_Q3=180
TTL_Q4=120
TTL_Q5=600

# --- Latencia simulada del Generador de Respuestas (ms) ---
# Aproxima el costo de un computo geoespacial real
SIM_LATENCY_MIN_MS=30
SIM_LATENCY_MAX_MS=120

# --- Modo Kafka (Tarea 2) ---
# true = Modo asincrono con colas Kafka (Tarea 2)
# false = Modo sincrono directo HTTP (Tarea 1)
USE_KAFKA=true

# Numero maximo de reintentos antes de enviar a la Dead Letter Queue
MAX_RETRIES=3
